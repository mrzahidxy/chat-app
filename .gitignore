# Root gitignore to cover client and api artifacts

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# Env files
.env
.env.*
!.env.example
api/.env
api/.env.*
!api/.env.example
client/.env
client/.env.*
!client/.env.example

# Node modules
node_modules
api/node_modules
client/node_modules

# Build outputs
dist
build
api/dist
client/dist

# Vite/coverage caches
.vite
coverage
logs

.vercel
